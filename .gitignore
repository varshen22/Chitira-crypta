*_stego.png
*_stego.jpg

# ── Secrets / keys ───────────────────────────────────────────────────────────
*.key
*.pem
*.env
secrets.txt
passphrase.txt

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
